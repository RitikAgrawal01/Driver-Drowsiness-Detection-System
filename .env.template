# ═══════════════════════════════════════════════════════════════
# Driver Drowsiness Detection System — Environment Variables
# Copy to .env and fill in values.
# NEVER commit .env to Git.
# ═══════════════════════════════════════════════════════════════

# ── Ports ───────────────────────────────────────────────────────
FRONTEND_PORT=3000
BACKEND_PORT=8000
MODEL_SERVER_PORT=8001
MLFLOW_PORT=5000
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
AIRFLOW_PORT=8080

# ── Environment ─────────────────────────────────────────────────
ENVIRONMENT=production
LOG_LEVEL=INFO

# ── Feature Engineering ─────────────────────────────────────────
SLIDING_WINDOW_SIZE=30
EAR_THRESHOLD=0.25
MAR_THRESHOLD=0.60
CONFIDENCE_THRESHOLD=0.7
DRIFT_SCORE_THRESHOLD=0.15

# ── MLflow ──────────────────────────────────────────────────────
MLFLOW_MODEL_NAME=drowsiness_classifier
MLFLOW_MODEL_STAGE=Production

# ── Airflow ─────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=

# ── Grafana ─────────────────────────────────────────────────────
# (Set in monitoring/grafana/grafana.env)

# ── Frontend build args (used by Docker build, not runtime) ─────
# MUST USE 127.0.0.1 INSTEAD OF localhost TO BYPASS WSL/WINDOWS IPv6 BUG
VITE_BACKEND_URL=http://127.0.0.1:8000
VITE_WS_URL=ws://127.0.0.1:8000
VITE_GRAFANA_URL=http://127.0.0.1:3001
VITE_MLFLOW_URL=http://127.0.0.1:5000
VITE_AIRFLOW_URL=http://127.0.0.1:8080
VITE_PROMETHEUS_URL=http://127.0.0.1:9090
