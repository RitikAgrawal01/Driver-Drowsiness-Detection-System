{
  "uid": "ddd-main",
  "title": "Driver Drowsiness Detection — Live Monitor",
  "description": "Real-time monitoring dashboard for the DDD system",
  "tags": ["ddd", "drowsiness", "mlops"],
  "timezone": "browser",
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "schemaVersion": 38,
  "version": 1,
  "panels": [

    {
      "id": 1,
      "title": "Active Sessions",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "short",
          "displayName": "Active Sessions"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "ddd_active_sessions",
          "legendFormat": "Sessions"
        }
      ]
    },

    {
      "id": 2,
      "title": "Model Server Status",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }
          ],
          "displayName": "Model Server"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "ddd_model_server_reachable",
          "legendFormat": "Model Server"
        }
      ]
    },

    {
      "id": 3,
      "title": "Overall Drift Score",
      "type": "gauge",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.10 },
              { "color": "red", "value": 0.15 }
            ]
          },
          "min": 0,
          "max": 0.5,
          "unit": "short",
          "displayName": "Drift Score"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "ddd_overall_drift_score",
          "legendFormat": "Overall Drift"
        }
      ]
    },

    {
      "id": 4,
      "title": "Drowsy Alerts (Total)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 3 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "short",
          "displayName": "Drowsy Alerts"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "ddd_drowsy_alerts_total",
          "legendFormat": "Alerts"
        }
      ]
    },

    {
      "id": 5,
      "title": "Error Rate %",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.02 },
              { "color": "red", "value": 0.05 }
            ]
          },
          "unit": "percentunit",
          "displayName": "Error Rate"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(ddd_request_errors_total[5m]) / (rate(ddd_requests_total[5m]) + 0.001)",
          "legendFormat": "Error Rate"
        }
      ]
    },

    {
      "id": 6,
      "title": "Frames Processed / sec",
      "type": "stat",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "displayName": "Frames/sec",
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(ddd_frames_processed_total[1m])",
          "legendFormat": "Frames/sec"
        }
      ]
    },

    {
      "id": 10,
      "title": "Inference Latency (P50 / P95 / P99)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom",
                    "calcs": ["mean", "max", "last"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, rate(ddd_inference_latency_seconds_bucket[2m])) * 1000",
          "legendFormat": "P50 latency"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, rate(ddd_inference_latency_seconds_bucket[2m])) * 1000",
          "legendFormat": "P95 latency (SLA)"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, rate(ddd_inference_latency_seconds_bucket[2m])) * 1000",
          "legendFormat": "P99 latency"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "200",
          "legendFormat": "SLA threshold (200ms)"
        }
      ]
    },

    {
      "id": 11,
      "title": "Prediction Confidence Distribution",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom",
                    "calcs": ["mean", "last"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 1,
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, rate(ddd_prediction_confidence_bucket[2m]))",
          "legendFormat": "P50 confidence"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, rate(ddd_prediction_confidence_bucket[2m]))",
          "legendFormat": "P95 confidence"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "0.7",
          "legendFormat": "Alert threshold (0.7)"
        }
      ]
    },

    {
      "id": 20,
      "title": "Feature Drift Scores (per feature)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 16, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "right",
                    "calcs": ["last", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "drift threshold" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "dash": [8, 4], "fill": "dash" } },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "ddd_feature_drift_score",
          "legendFormat": "{{ feature }}"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "0.15",
          "legendFormat": "drift threshold"
        }
      ]
    },

    {
      "id": 21,
      "title": "Request Rate by Endpoint",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 12, "w": 8, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(ddd_requests_total[1m])",
          "legendFormat": "{{ endpoint }} ({{ status }})"
        }
      ]
    },

    {
      "id": 30,
      "title": "Feature Extraction Latency",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 6 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, rate(ddd_feature_extraction_latency_seconds_bucket[2m])) * 1000",
          "legendFormat": "P95 MediaPipe extraction"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, rate(ddd_feature_extraction_latency_seconds_bucket[2m])) * 1000",
          "legendFormat": "P50 MediaPipe extraction"
        }
      ]
    },

    {
      "id": 31,
      "title": "Drowsy Alerts Rate",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 6 },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": { "lineWidth": 2, "fillOpacity": 20 }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(ddd_drowsy_alerts_total[1m]) * 60",
          "legendFormat": "Alerts per minute"
        }
      ]
    }
  ]
}
