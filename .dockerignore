# .dockerignore
# Exclude files from Docker build context to keep images small and fast

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual envs
.venv/
venv/
env/

# Environment
.env
.env.*

# Git
.git/
.gitignore
.gitattributes

# DVC
.dvc/
*.dvc

# Data (large — tracked by DVC, not needed in image)
data/
mlruns/
mlartifacts/

# Logs
logs/
*.log

# Tests
tests/
coverage.xml
.pytest_cache/
htmlcov/

# Frontend (if in root context)
frontend/node_modules/
frontend/dist/

# IDE
.vscode/
.idea/

# Docs
docs/
*.md

# Reports (generated at runtime)
reports/

# Scripts
tools/

# OS
.DS_Store
Thumbs.db
